# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/aquafilter
MONGO_URI_PROD=mongodb+srv://<user>:<password>@cluster.mongodb.net/aquafilter

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ESP32 Telemetry HMAC Secret (shared with NodeMCU firmware)
DEVICE_HMAC_SECRET=your_esp32_shared_hmac_secret_key

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your_expo_access_token

# Filter Replacement Threshold (cumulative filtration cycles)
FILTER_REPLACEMENT_CYCLE_LIMIT=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
